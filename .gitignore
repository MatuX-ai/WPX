resources/fonts/**/*.woff
resources/fonts/**/*.woff2
resources/fonts/**/*.ttc
resources/fonts/**/*.eot

# Built-in Pandoc binary (large — distributed separately or via install script)
resources/bin/pandoc/pandoc.exe
resources/bin/pandoc/pandoc
resources/bin/pandoc/pandoc-*

