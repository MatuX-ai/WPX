# =============================================================================
# WPX Server - 环境变量示例
# 复制为 .env 后按部署环境修改。生产环境务必不要使用 AUTH_BYPASS=true
# =============================================================================

# -------- 服务基础 --------
PORT=3000
NODE_ENV=development
# 进程对外暴露的 URL（用于生成绝对 URL / 健康检查返回）
PUBLIC_HOST=http://localhost:3000
# API 网关主域名（用于日志/响应头标识）
API_DOMAIN=api.prowpx.com

# -------- 反向代理 --------
# 信任的反向代理跳数：Nginx 单层 = 1；Aliyun SLB + Nginx = 2；直接暴露 = 0
TRUST_PROXY_HOPS=1

# -------- PostgreSQL --------
# 本地开发
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=wpx
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
# 云数据库（阿里云 RDS / Railway Postgres / Render Postgres）需开启 SSL
PG_SSL=false
PG_SSL_REJECT_UNAUTHORIZED=true

# -------- Redis --------
# 本地
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
# Railway/Upstash 示例：
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# -------- JWT 鉴权（prowpx.com 自托管邮箱认证） --------
# 与认证服务共享的密钥（HS256）或 PEM 公钥（RS256）
ACCOUNT_JWT_SECRET=replace_with_prowpx_shared_secret
ACCOUNT_JWT_ALG=HS256
ACCOUNT_JWT_ISSUER=prowpx.com
ACCOUNT_JWT_AUDIENCE=wpx-server
# Token 有效期（可选，未设置则使用默认 2h / 30d）
ACCOUNT_ACCESS_TOKEN_TTL=2h
ACCOUNT_REFRESH_TOKEN_TTL=30d
# 本地开发才设为 true；生产必须 false
AUTH_BYPASS=false
# AUTH_BYPASS=true 时使用的角色白名单，便于本地联调 admin 接口
AUTH_BYPASS_ROLES=admin
# 密码哈希成本因子（bcrypt，OWASP 推荐 >= 10；默认 12）
BCRYPT_COST=12

# -------- CORS --------
# 多个域名用英文逗号分隔；* 表示放行任意源（不可与 credentials=true 同时使用）
# 推荐配置：
CORS_ORIGIN=https://prowpx.com,https://www.prowpx.com,https://api.prowpx.com,https://admin.prowpx.com,http://localhost:5174,http://localhost:5175
CORS_CREDENTIALS=true

# -------- CDN / 静态资源 --------
# 可选：对象存储 / CDN 域名（用于生成静态资源绝对 URL）
CDN_BASE=https://cdn.prowpx.com

# -------- 邮件服务（SMTP） --------
# 用于发送注册验证邮件与找回密码邮件
# 不配置时进入日志模式：仅打印邮件内容到控制台，不会真实发送
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@prowpx.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM="WPX <noreply@prowpx.com>"
# 邮件模板中链接的公共 URL（生成验证链接 / 重置链接时使用）
PUBLIC_WEB_BASE=https://prowpx.com

# -------- 日志 --------
LOG_LEVEL=info

# -------- 请求体 --------
BODY_LIMIT=1mb
