# =============================================================================
# WPX Server - 环境变量示例
# 复制为 .env 后按部署环境修改。生产环境务必不要使用 AUTH_BYPASS=true
# =============================================================================

# -------- 服务基础 --------
PORT=3000
NODE_ENV=development
# 进程对外暴露的 URL（用于生成绝对 URL / 健康检查返回）
PUBLIC_HOST=http://localhost:3000
# API 网关主域名（用于日志/响应头标识）
API_DOMAIN=api.proclaw.cc

# -------- 反向代理 --------
# 信任的反向代理跳数：Nginx 单层 = 1；Aliyun SLB + Nginx = 2；直接暴露 = 0
TRUST_PROXY_HOPS=1

# -------- PostgreSQL --------
# 本地开发
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=wpx
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
# 云数据库（阿里云 RDS / Railway Postgres / Render Postgres）需开启 SSL
PG_SSL=false
PG_SSL_REJECT_UNAUTHORIZED=true

# -------- Redis --------
# 本地
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
# Railway/Upstash 示例：
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# -------- JWT 鉴权（account.proclaw.cc 颁发） --------
# 与账户中心约定一致的共享密钥（HS256）或 PEM 公钥（RS256）
ACCOUNT_JWT_SECRET=replace_with_account_proclaw_shared_secret
ACCOUNT_JWT_ALG=HS256
ACCOUNT_JWT_ISSUER=account.proclaw.cc
ACCOUNT_JWT_AUDIENCE=wpx-server
# 本地开发才设为 true；生产必须 false
AUTH_BYPASS=false
# AUTH_BYPASS=true 时使用的角色白名单，便于本地联调 admin 接口
AUTH_BYPASS_ROLES=admin

# -------- CORS --------
# 多个域名用英文逗号分隔；* 表示放行任意源（不可与 credentials=true 同时使用）
# 推荐配置：
CORS_ORIGIN=https://proclaw.cc,https://www.proclaw.cc,https://landing.proclaw.cc,https://admin.proclaw.cc,http://localhost:5174,http://localhost:5175
CORS_CREDENTIALS=true

# -------- CDN / 静态资源 --------
# 可选：对象存储 / CDN 域名（用于生成静态资源绝对 URL）
CDN_BASE=https://cdn.proclaw.cc

# -------- 日志 --------
LOG_LEVEL=info

# -------- 请求体 --------
BODY_LIMIT=1mb# 服务运行端口
PORT=3000
NODE_ENV=development

# PostgreSQL 数据库配置
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=wpx
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 鉴权 - 账户中心
# account.proclaw.cc 颁发的 JWT 共享密钥
ACCOUNT_JWT_SECRET=replace_with_account_proclaw_shared_secret
ACCOUNT_JWT_ALG=HS256
ACCOUNT_JWT_ISSUER=account.proclaw.cc
ACCOUNT_JWT_AUDIENCE=wpx-server
# 可选：是否允许本地开发期间跳过 JWT 校验（生产必须为 false）
AUTH_BYPASS=false

# 跨域白名单（逗号分隔，* 表示全部）
CORS_ORIGIN=*

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 请求体最大字节（默认 1mb）
BODY_LIMIT=1mb
