{
  "mcpServers": {
    "wpx-dev": {
      "command": "node",
      "args": [".cursor/mcp/wpx-dev-server.mjs"]
    },
    "wpx-jcode": {
      "command": "node",
      "args": [".cursor/mcp/wpx-jcode-server.mjs"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--allowed-origins=http://localhost:5173;http://127.0.0.1:5173"
      ]
    }
  }
}
