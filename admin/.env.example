# =============================================================================
# WPX 管理后台 - 环境变量示例
# 复制为 .env 后按部署环境修改。
# =============================================================================

# 应用标题
VITE_APP_TITLE=WPX 管理后台

# 浏览器标签短标题
VITE_APP_SHORT_NAME=WPX Admin

# 品牌主色（与 landing 保持一致）
VITE_THEME_COLOR=#4F46E5

# ----------------------------------------------------------------------------
# 业务 API（默认走主站 /api 反向代理，同源无 CORS）
#   生产部署域名：prowpx.com（管理后台挂在 /admin 路径下）
#   通过 /api/* 由网关反代到后端 prowpx.com/admin/api/*（同源，无跨域）
#   Vercel Serverless Function: /api/* -> /api/proxy -> https://www.prowpx.com/admin/api/*
# 如需直连独立子域后端（如 staging），请改为完整 URL 并确保后端开启 CORS：
#   VITE_API_BASE_URL=https://staging.prowpx.com/admin/api
#
# ⚠️ 不要使用 'https://prowpx.com' / 'https://www.prowpx.com' 等域名做 baseURL！
#    当前 Vercel 项目对 apex 域名配置了 "Redirect to www"（308 重定向，
#    在 Vercel Dashboard 的 Domain Settings 里手动启用），跨子域请求会让 CORS preflight
#    被 308 阻断，POST 完全失败。务必用相对路径 / 或 /api（同源请求不会触发跨子域 308）。
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=/api

# ----------------------------------------------------------------------------
# 认证服务：WPX 自托管邮箱认证
# 统一从主域 prowpx.com 提供（不再使用独立的 account 子域）
# 登录表单直接提交到 /api/auth/login（前端默认 baseURL=/，同源）
#
# ⚠️ 同上，绝对不要写成 'https://prowpx.com'，否则会触发 CORS preflight 308 阻断。
# ----------------------------------------------------------------------------
VITE_ACCOUNT_BASE_URL=/
