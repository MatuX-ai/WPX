# =============================================================================
# WPX 管理后台 - 环境变量示例
# 复制为 .env 后按部署环境修改。
# =============================================================================

# 应用标题
VITE_APP_TITLE=WPX 管理后台

# 浏览器标签短标题
VITE_APP_SHORT_NAME=WPX Admin

# 品牌主色（与 landing 保持一致）
VITE_THEME_COLOR=#4F46E5

# ----------------------------------------------------------------------------
# 业务 API（默认走主站 /api 反向代理，同源无 CORS）
#   生产部署域名：prowpx.com（管理后台挂在 /admin 路径下）
#   通过 /api/* 由网关反代到后端 api.prowpx.com/admin/*
#   Cloudflare Pages Functions:  /api/* -> https://api.prowpx.com/admin/*
#   Vercel Serverless Function:  /api/* -> https://api.prowpx.com/admin/*
# 如需直连后端，请改为完整 URL 并确保后端开启 CORS：
#   VITE_API_BASE_URL=https://api.prowpx.com/admin
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=/api

# ----------------------------------------------------------------------------
# 认证服务：WPX 自托管邮箱认证
# 统一从主域 prowpx.com 提供（不再使用独立的 account 子域）
# 登录表单直接提交到 https://prowpx.com/api/auth/login
# ----------------------------------------------------------------------------
VITE_ACCOUNT_BASE_URL=/
