# WPX · Vercel 部署忽略规则
# 用于在 Vercel 构建时跳过与前端无关的子项目，避免无谓的 npm install 和上传体积
#
# 重要：landing/src/ 和 admin/src/ 不能排除！Vite 需要它们进行构建，
#       index.html 引用了 src/entry-client.js / src/main.js 作为入口。
#       构建产物的项目根文件（index.html, assets/, wp-admin/, api/proxy.js）
#       由 build-frontend.js 从 landing/dist/ + admin/dist/ + admin/api/proxy.js 合并而来。
#
# ⚠️ 必须保留的构建依赖文件（不能整目录排除）：
#   - landing/package.json, index.html, vite.config.js, tailwind.config.js, postcss.config.js
#   - admin/package.json, index.html, vite.config.js, tailwind.config.js, postcss.config.js, api/proxy.js
#   - scripts/build-frontend.js
#   缺少任何一个都会导致 installCommand / buildCommand 失败。

# === 项目根：只排除项目根的 package.json（子项目的 package.json 必须保留）===
/package.json
/package-lock.json

# === landing 子项目：排除 IDE/文档，保留 src/（Vite 构建需要）+ public/（Vite 构建输出来源） ===
# 注：landing/public/ 不能排除！Vite 构建时会将 public/ 下的文件（og-image.svg、favicon.svg、
#     robots.txt、sitemap.xml 等）原样复制到 dist/。缺少则页面 404。
#     _redirects / _headers 虽在其中，但 build-frontend.js 会从输出中自动删除。
landing/.vscode/**
/landing/.env.production.example
/landing/README.md

# === admin 子项目：排除 IDE/文档/CF Functions/配置文件，保留 src/（Vite 构建需要） ===
admin/.vscode/**
/admin/.env.example
/admin/ADMIN_INIT.md
/admin/DEPLOY.md
/admin/vercel.json
# admin/functions/ 是 Cloudflare Pages Functions，不是 Vercel Function
admin/functions/**/*
admin/public/**

# === scripts：保留 build-frontend.js（Vercel buildCommand 需要），排除其他 ===
/scripts/build-electron.ps1
/scripts/bump-pack-version.mjs
/scripts/force-build.mjs
/scripts/generate-icons.mjs
/scripts/run-build.mjs
/scripts/smoke-prod-electron.mjs
/scripts/smoke-prod-runner.cjs

# === Electron 桌面端（与 Vercel 无关） ===
electron/**
wpx-app/**

# === Express 后端（仅作为代码仓库，不上传到 Vercel） ===
# ⚠️ 关键：必须完全排除项目根 server/！
#   否则 Vercel 会部署 server/ 下的 46 个 .js 文件（routes/controllers/middleware/utils/services/models），
#   全部被识别为 Serverless Function，超出 Hobby 计划 12 Function 限制，报错：
#   "No more than 12 Serverless Functions can be added to a Deployment on the Hobby plan"。
#   build-frontend.js 把 server/ 复制到 public/api/admin/_server/（Vercel Function 运行时定位）
#   + 项目根 _server/（本地 dev 兼容）。下划线开头 _server/ 使 Vercel 不扫描其内部为 Function，
#   避免 12 Function 限制，同时仍会上传到部署包。
server/

# === 打包产物 / 资源 ===
release/**
resources/**

# 依赖相关
**/node_modules/
# ⚠️ 例外（2026-06-30 修正）：必须保留 _server/ 下的 node_modules。
#   build-frontend.js 把 server/node_modules 复制到 _server/node_modules/
#   让 Vercel Function 容器运行时能找到 express/cors/helmet/pg/redis 等依赖。
#   若保留上面 **/node_modules/ 全局规则，_server/ 下的依赖会被全部排除，
#   运行时 require('express') 会报 Cannot find module，返回 500 FUNCTION_INVOCATION_FAILED。
#   关键：_server/ 必须在项目根顶层（不在 api/ 下），Vercel 不扫描整个目录；
#   否则即使下划线前缀，Vercel 仍会扫描 api/_server/ 下 46 个 .js 触发 12 Function 限制。
#   ⚠️ Vercel 部署调试发现：!_server/node_modules/** 在某些场景下未被识别，
#   需要补上更明确的 !_server/node_modules 和 !_server/node_modules/** 两个例外。
!_server/node_modules
!_server/node_modules/**

# ⚠️ 例外（2026-07-01 修正）：必须保留 public/api/admin/_server/node_modules/。
#   build-frontend.js 把 server/node_modules 复制到 public/api/admin/_server/node_modules/
#   （路径：/var/task/api/admin/_server/node_modules/），
#   这是 handler.js 运行时实际依赖的位置。上面的 **/node_modules/ 全局规则会默认排除它，
#   必须加 ! 例外保留，否则运行时 require('express') 会报 Cannot find module → 502/500。
#   注意：_server/ 以下划线开头，Vercel 不扫描其内部 .js 为 Function（避免 12 Function 限制），
#   但仍会上传到部署包供运行时 require 解析。
!public/api/admin/_server/node_modules
!public/api/admin/_server/node_modules/**

# Vite/Vitest 缓存
.vite/
*.tsbuildinfo

# 测试报告
playwright-report/**
test-results/**
coverage/**

# 编辑器 / 系统文件
.DS_Store
Thumbs.db
*.log
build-*.log
smoke-result.json
plan.md
test-write.txt

# Storybook / E2E 临时产物
wpx-app/storybook-static/**
wpx-app/tex2pdf.*/

# 文档
docs/**

# CI 配置
.cursor/**
.github/**