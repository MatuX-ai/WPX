# WPX · Vercel 部署忽略规则
# 用于在 Vercel 构建时跳过与前端无关的子项目，避免无谓的 npm install 和上传体积
#
# 重要：landing/src/ 和 admin/src/ 不能排除！Vite 需要它们进行构建，
#       index.html 引用了 src/entry-client.js / src/main.js 作为入口。
#       构建产物的项目根文件（index.html, assets/, wp-admin/, api/proxy.js）
#       由 build-frontend.js 从 landing/dist/ + admin/dist/ + admin/api/proxy.js 合并而来。
#
# ⚠️ 必须保留的构建依赖文件（不能整目录排除）：
#   - landing/package.json, index.html, vite.config.js, tailwind.config.js, postcss.config.js
#   - admin/package.json, index.html, vite.config.js, tailwind.config.js, postcss.config.js, api/proxy.js
#   - scripts/build-frontend.js
#   缺少任何一个都会导致 installCommand / buildCommand 失败。

# === 项目根：只排除项目根的 package.json（子项目的 package.json 必须保留）===
/package.json
/package-lock.json

# === landing 子项目：排除 IDE/文档/配置文件，保留 src/（Vite 构建需要） ===
# 注：landing/src/ 必须保留，因为 vite.config.js 和 index.html 都引用 src/ 下的文件
#     landing/public/ 排除可接受（Vite 对缺失 public/ 仅告警不报错）
landing/.vscode/**
/landing/.env.production.example
landing/public/**
/landing/README.md

# === admin 子项目：排除 IDE/文档/CF Functions/配置文件，保留 src/（Vite 构建需要） ===
admin/.vscode/**
/admin/.env.example
/admin/ADMIN_INIT.md
/admin/DEPLOY.md
/admin/vercel.json
# admin/functions/ 是 Cloudflare Pages Functions，不是 Vercel Function
admin/functions/**/*
admin/public/**

# === scripts：保留 build-frontend.js（Vercel buildCommand 需要），排除其他 ===
/scripts/build-electron.ps1
/scripts/bump-pack-version.mjs
/scripts/force-build.mjs
/scripts/generate-icons.mjs
/scripts/run-build.mjs
/scripts/smoke-prod-electron.mjs
/scripts/smoke-prod-runner.cjs

# === Electron 桌面端（与 Vercel 无关） ===
electron/**
wpx-app/**

# === Express 后端（部署到 Render/Railway，不上 Vercel） ===
server/**

# === 打包产物 / 资源 ===
release/**
resources/**

# 依赖相关
**/node_modules/

# Vite/Vitest 缓存
.vite/
*.tsbuildinfo

# 测试报告
playwright-report/**
test-results/**
coverage/**

# 编辑器 / 系统文件
.DS_Store
Thumbs.db
*.log
build-*.log
smoke-result.json
plan.md
test-write.txt

# Storybook / E2E 临时产物
wpx-app/storybook-static/**
wpx-app/tex2pdf.*/

# 文档
docs/**

# CI 配置
.cursor/**
.github/**