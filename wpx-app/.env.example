VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 可选：导出服务地址，留空则使用 Vite 代理（/api/export → localhost:3001）
# Electron 桌面端由主进程本地服务自动注入，无需配置
# VITE_EXPORT_API_URL=http://localhost:3001
# 可选：去背景服务地址，留空则使用 Vite 代理（/api/remove-bg → localhost:3002）
# VITE_REMOVE_BG_API_URL=http://localhost:3002
# 可选：资料库服务地址，留空则使用 Vite 代理（/api/knowledge → localhost:3003）
# VITE_KNOWLEDGE_API_URL=http://localhost:3003
# 可选：文库服务地址，留空则使用 Vite 代理（/api/library → localhost:3004）
# VITE_LIBRARY_API_URL=http://localhost:3004
# 可选：文库保存根目录（后端环境变量 LIBRARY_ROOT_DIR）
