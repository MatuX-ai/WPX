# =============================================================================
# WPX Vercel 部署 - 环境变量（配置在 Vercel Dashboard → Project Settings → Environment Variables）
# 这些变量被 server/ 后端 + api/admin/handler.js 读取
# =============================================================================
#
# ⚠️ 重要：本文件只是文档示例，不要把真实密钥提交到 git
# 在 Vercel Dashboard 配环境变量时：
#   - Production 必填（运营 / 用户认证需要）
#   - Preview 可选（开发预览用）
#   - Development 本地用 .env.local
#
# 本文件复制到 .env.example.vercel 后再修改也无意义——Vercel 不读本地 .env。
# 直接在 Vercel Dashboard 配置即可。
# =============================================================================

# -------- 服务基础 --------
NODE_ENV=production
# API 网关主域名（用于日志/响应头标识）
API_DOMAIN=admin.prowpx.com
# 邮件中链接的公共 Web URL（生成验证 / 重置链接时使用）
PUBLIC_WEB_BASE=https://prowpx.com

# -------- 反向代理 --------
# Vercel Function 经过一层 CDN → 1
TRUST_PROXY_HOPS=1

# -------- PostgreSQL（推荐 Neon：https://neon.tech） --------
# 【推荐】直接贴 Neon 控制台 → Connection Details → connection string（带 sslmode=require）
# 后代码优先读这里；未配置时退回下面拆分的 PG_* 字段
DATABASE_URL=postgres://neondb_owner:your_password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# 本地直连 / 连接串不含 sslmode 时用下面这些字段（拆成 host/port/user/password/database）
# PG_HOST=ep-xxx.us-east-2.aws.neon.tech
# PG_PORT=5432
# PG_USER=neondb_owner
# PG_PASSWORD=your_neon_password
# PG_DATABASE=neondb
PG_POOL_MAX=5
PG_IDLE_TIMEOUT_MS=10000
# Neon / 阿里云 RDS / Railway Postgres 都必须开启 SSL。
# 若 DATABASE_URL 已包含 sslmode=require，下面这两个可省略；保留仅供连接串不含 SSL 参数时使用
# PG_SSL=true
# PG_SSL_REJECT_UNAUTHORIZED=false

# -------- Redis（Vercel KV 或 Upstash） --------
# 必填；如果没配 Redis，登录 / 注册仍可用，但 token 黑名单 / 限流失效
# Vercel KV: Project → Storage → KV → 选 Database → Copy env vars
# Upstash:    控制台 → Redis → Copy REST URL / Token
# 推荐使用 Upstash：
REDIS_URL=rediss://default:your_token@your-host.upstash.io:6379
REDIS_PASSWORD=
REDIS_DB=0

# -------- JWT 鉴权（prowpx.com 自托管邮箱认证） --------
# 用强随机 32+ 字节密钥（命令行：openssl rand -hex 32）
ACCOUNT_JWT_SECRET=replace_with_64_char_random_hex
ACCOUNT_JWT_ALG=HS256
ACCOUNT_JWT_ISSUER=prowpx.com
ACCOUNT_JWT_AUDIENCE=wpx-admin
# Token 有效期
ACCOUNT_ACCESS_TOKEN_TTL=2h
ACCOUNT_REFRESH_TOKEN_TTL=30d
# 生产环境必须 false（否则任何人都能绕过 JWT）
AUTH_BYPASS=false
# bcrypt 成本因子（Vercel Function 跑 bcrypt 比较慢，建议降到 8-10）
BCRYPT_COST=8

# -------- CORS --------
# Vercel Function 跟浏览器同源（/admin/api/* 是同源），通常不需要 CORS
# 但保留配置以便 /api/proxy 反代到 /admin/api/* 时 server/ 的 cors 中间件能正确处理
CORS_ORIGIN=https://prowpx.com,https://www.prowpx.com
CORS_CREDENTIALS=true

# -------- 邮件服务（SMTP / Resend） --------
# Resend 推荐：https://resend.com （Vercel 友好，免费额度 3000 邮件/月）
# RESEND_API_KEY=re_xxx
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_xxx
# SMTP_FROM="WPX <noreply@prowpx.com>"
#
# 如果都不配，email-service 进入"日志模式"：
#   - 验证邮件 / 重置邮件不会真实发送
#   - 验证链接会打印到 Vercel 函数日志
#   - 用户仍能正常注册 + 登录（不强制邮箱验证）
#
# 推荐用 Resend：
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM="WPX <noreply@prowpx.com>"

# -------- 日志 --------
LOG_LEVEL=info

# -------- 请求体 --------
BODY_LIMIT=1mb

# =============================================================================
# 一次性数据库初始化（部署后必须执行）
# =============================================================================
# 拿到 Neon DATABASE_URL 后，在本地运行：
#   psql "postgres://user:pass@host/db?sslmode=require" -f server/sql/init.sql
#
# 初始化脚本会创建以下表：
#   users / user_profiles / usage_events / payments
#   ai_models / model_call_logs
#   fonts / font_usage_logs
#   skills
#   token_orders / token_consumptions
#   announcements
#   versions
#   system_settings
#   admin_users
#   operation_logs
#
# 第一个注册的用户会自动获得 ['admin', 'user'] 角色（bootstrap 逻辑），
# 后续注册的用户默认 ['user']。如需手动晋升：
#   UPDATE users SET roles = ARRAY['admin','user'] WHERE email = '[email protected]';